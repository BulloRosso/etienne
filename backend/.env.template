# Coding Agent Selection:
#   'anthropic'      — Claude Code SDK (Anthropic)
#   'openai'         — Codex SDK (OpenAI, subprocess via JSON-RPC stdio)
#   'openai-agents'  — OpenAI Agents SDK (library-based, agents-as-tools orchestration)
#   'pi-mono'        — More aggressive and user controlled approach (used in OpenClaw, no native MCP Support)
#   'open-code'      — OpenCode SDK (SST, multi-provider, LSP integration, native MCP/subagents/skills)
CODING_AGENT=anthropic

# Anthropic API Key (required when CODING_AGENT=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API Key (required when CODING_AGENT=openai or CODING_AGENT=openai-agents)
# NOTE: Also required for scrapbook embeddings feature regardless of CODING_AGENT setting
OPENAI_API_KEY=

# OpenAI Agents SDK Configuration (only used when CODING_AGENT=openai-agents)
# OPENAI_AGENTS_MODEL=gpt-5.3-codex
# OPENAI_AGENTS_ENABLE_CODEX_TOOL=false
# OPENAI_AGENTS_PERMISSION_TIMEOUT_MS=300000

# OpenCode Configuration (only used when CODING_AGENT=open-code)
# OPENCODE_PROVIDER=anthropic
# OPENCODE_MODEL=claude-sonnet-4-5-20250514
# OPENCODE_PERMISSION_TIMEOUT_MS=300000
# OPENCODE_SERVER_PORT=0
# OPENCODE_BINARY_PATH=opencode

# Model tiers per provider (comma-separated: small,regular)
ANTHROPIC_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-5-20250929
OPENAI_MODELS=gpt-5-mini,gpt-5.2

# LiteLLM Proxy Configuration (used when aiModel=openai)
# LiteLLM translates Anthropic API format to OpenAI backends
# Claude Code → LiteLLM Proxy (:4000) → OpenAI (gpt-5-codex, gpt-5-mini)
# Configuration is in litellm-proxy/config.yaml
# Master key configured in litellm-proxy/.env

# Observability - Provider Selection
# OBSERVABILITY_PROVIDER: 'phoenix' (default), 'azure', or 'aws'
OBSERVABILITY_PROVIDER=phoenix
OTEL_ENABLED=true
OTEL_SERVICE_NAME=etienne
# OTEL_SPAN_PROCESSOR: 'batch' (default) or 'simple' (immediate flush, dev only)
OTEL_SPAN_PROCESSOR=batch

# Observability - Phoenix Arize (when OBSERVABILITY_PROVIDER=phoenix)
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Observability - Azure Application Insights (when OBSERVABILITY_PROVIDER=azure)
# Paste the connection string from your App Insights resource in the Azure portal.
AZURE_MONITOR_CONNECTION_STRING=

# Observability - AWS CloudWatch / X-Ray OTLP (when OBSERVABILITY_PROVIDER=aws)
# Credentials are resolved via the default AWS credential chain
# (env vars, shared credentials file, instance role).
# AWS_OTEL_ENDPOINT defaults to https://xray.<region>.amazonaws.com/v1/traces.
AWS_OTEL_REGION=
AWS_OTEL_ENDPOINT=

# Memory Management Configuration
MEMORY_MANAGEMENT_URL=http://localhost:6060/api/memories
MEMORY_DECAY_DAYS=6
WORKSPACE_ROOT=

# Project Scope Isolation (sandbox filesystem restrictions)
# true (default): agent can only read/write within its own project directory
# false: agent can read sibling project directories but cannot write to them
FORCE_PROJECT_SCOPE=true

# Budget Control Configuration
COSTS_CURRENCY_UNIT=EUR
COSTS_PER_MIO_INPUT_TOKENS=3.0
COSTS_PER_MIO_OUTPUT_TOKENS=15.0

# MCP Tools
DIFFBOT_TOKEN=
VAPI_TOKEN=
IMAGE_GENERATION_API_KEY=

# Checkpoint Provider Configuration
CHECKPOINT_PROVIDER=gitea-project
GITEA_URL=http://localhost:3000
GITEA_USERNAME=
GITEA_PASSWORD=
GITEA_REPO=workspace-checkpoints

# Email Configuration
# SMTP_CONNECTION format: host|port|secure|user|password
# Port 587 uses STARTTLS (secure=false triggers STARTTLS mode)
# Port 993 uses direct SSL/TLS (secure=true)
SMTP_CONNECTION=

# IMAP_CONNECTION format: host|port|secure|user|password
# IMAP uses SSL on port 993
IMAP_CONNECTION=

# SMTP Whitelist - comma-separated list of allowed recipients
# This prevents AI agents from sending emails to unauthorized recipients
SMTP_WHITELIST=

# Agent Bus Logging — per-service JSONL trace logs
# Each path is relative to WORKSPACE_ROOT/<project>/
AGENT_BUS_LOG_CMS=.etienne/agent-logs/cms.jsonl
AGENT_BUS_LOG_DSS=.etienne/agent-logs/dss.jsonl
AGENT_BUS_LOG_SWE=.etienne/agent-logs/swe.jsonl

# File Previewer Mappings (pipe-separated: viewer:.ext1,.ext2)
REGISTERED_PREVIEWERS=html:.html,.htm|json:.json|jsonl:.jsonl|markdown:.md|mermaid:.mermaid|research:.research|image:.jpg,.jpeg,.png,.gif|excel:.xls,.xlsx|prompt:.prompt|workflow:.workflow.json|scrapbook:.scbk|video:.youtube,.videos,.mp4|knowledge:.knowledge|pdf:.pdf|docx:.docx,.doc

# Secrets Manager Configuration
# Provider: 'openbao' (default), 'azure-keyvault', 'aws', or 'env' (fallback to process.env only)
SECRET_VAULT_PROVIDER=openbao
OPENBAO_ADDR=http://127.0.0.1:8200
OPENBAO_DEV_ROOT_TOKEN=dev-root-token

# Azure Key Vault Configuration (only used when SECRET_VAULT_PROVIDER=azure-keyvault)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_VAULT_URL=

# AWS Secrets Manager Configuration (only used when SECRET_VAULT_PROVIDER=aws)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional prefix to namespace secrets (e.g. 'myapp' stores keys as 'myapp/KEY_NAME')
AWS_SECRETS_PREFIX=

# Authentication Provider Configuration
# Provider: 'local' (default, uses oauth-server), 'azure-entraid', or 'aws-cognito'
AUTH_PROVIDER=local

# Azure Entra ID Authentication (only used when AUTH_PROVIDER=azure-entraid)
# Client secret should be stored in secrets-manager rather than here
AZURE_ENTRAID_TENANT_ID=
AZURE_ENTRAID_CLIENT_ID=
AZURE_ENTRAID_CLIENT_SECRET=
AZURE_ENTRAID_REDIRECT_URI=
# Comma-separated Azure AD group IDs whose members receive the 'admin' role
AZURE_ENTRAID_ADMIN_GROUPS=

# AWS Cognito Authentication (only used when AUTH_PROVIDER=aws-cognito)
# Client secret should be stored in secrets-manager rather than here
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=
AWS_COGNITO_CLIENT_SECRET=
AWS_COGNITO_REGION=
AWS_COGNITO_DOMAIN=
# Comma-separated Cognito group names whose members receive the 'admin' role
AWS_COGNITO_ADMIN_GROUPS=
