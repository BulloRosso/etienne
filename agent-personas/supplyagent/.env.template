# =============================================================================
# SupplyAgent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# IMAP Configuration for supplier email monitoring (required)
IMAP_HOST=imap.example.com
IMAP_USER=supply@example.com
IMAP_PASSWORD=your-password-here

# SPARQL Endpoint (defaults to local quadstore)
SPARQL_ENDPOINT=http://localhost:7000

# Timezone for cron jobs (defaults to Europe/Berlin)
TIMEZONE=Europe/Berlin
